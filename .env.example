# ==========================================
# BILL STEIN PORTFOLIO - Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control!

# ==========================================
# EMAIL SERVICE (Resend)
# ==========================================
# Get your API key from: https://resend.com/api-keys
# Used for contact form email delivery
RESEND_API_KEY=re_your_api_key_here

# Your email address where contact form submissions will be sent
CONTACT_EMAIL=contact@billstein.dev

# ==========================================
# SITE CONFIGURATION
# ==========================================
# Your portfolio website URL (no trailing slash)
# Used for SEO meta tags and canonical URLs
NEXT_PUBLIC_SITE_URL=https://www.billsteincs.com

# ==========================================
# OPTIONAL: ANALYTICS & MONITORING
# ==========================================
# Google Analytics Measurement ID (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (automatically enabled on Vercel deployment)
# No configuration needed

# ==========================================
# OPTIONAL: GITHUB INTEGRATION
# ==========================================
# GitHub Personal Access Token (for fetching stats/activity)
# Generate at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
# GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username
# GITHUB_USERNAME=BillSteinUNB

# ==========================================
# OPTIONAL: RATE LIMITING
# ==========================================
# Upstash Redis URL (for rate limiting contact form)
# Get from: https://upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
# Set to 'true' to enable debug logging
# DEBUG=false
